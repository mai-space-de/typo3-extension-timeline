plugin.tx_maitimeline_timeline {
    view {
        templateRootPaths.0 = EXT:mai_timeline/Resources/Private/Templates/
        partialRootPaths.0 = EXT:mai_timeline/Resources/Private/Partials/
        layoutRootPaths.0 = EXT:mai_timeline/Resources/Private/Layouts/
    }
    persistence {
        storagePid = {$plugin.tx_maitimeline_timeline.persistence.storagePid}
    }
    settings {
        orderDirection = DESC
        limit = 0
        categoryUid = 0
    }
}
