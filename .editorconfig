root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.yml]
indent_size = 2

[*.yaml]
indent_size = 2

[*.xml]
indent_size = 4

[*.xlf]
indent_size = 4

[*.neon]
indent_style = tab

[*.md]
trim_trailing_whitespace = false

[composer.json]
indent_size = 4
